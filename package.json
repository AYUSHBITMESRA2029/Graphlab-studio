{
  "name": "graphlab-studio",
  "version": "1.0.0",
  "description": "GraphLab Studio is a standalone browser app for science stream students.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.graphlab.studio",
    "productName": "GraphLab Studio",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "build3"
    }
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  }
}
